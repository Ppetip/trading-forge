PORT=8787
HOST=127.0.0.1
NODE_ENV=development
EDGELAB_DB_PATH=./data/edgelab.sqlite
EDGELAB_DB_DRIVER=postgres
# Neon/Postgres connection string. Set EDGELAB_DB_DRIVER=sqlite for local SQLite fallback.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
EDGELAB_APP_URL=http://localhost:5173

# Stripe server credentials. Never expose these through VITE_ variables.
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRO_PRICE_ID=price_replace_me

# Legacy provider-neutral webhook retained for compatibility and isolated tests.
EDGELAB_BILLING_WEBHOOK_SECRET=replace-with-a-long-random-secret

MARKET_DATA_CACHE_PATH=./data/market-cache

# Historical market data
DATABENTO_API_KEY=replace_with_databento_key

# Explicit one-time admin bootstrap; never infer among multiple accounts.
EDGELAB_ADMIN_EMAIL=owner@example.com

# Keep this false for the public hosted API. Use `pnpm server:admin` on a
# trusted local/admin machine when the separate ops app needs admin endpoints.
EDGELAB_ENABLE_ADMIN_API=false

# Hosted AI inference through OpenRouter. Required for strategy parsing, preflight, and report review.
OPENROUTER_API_KEY=replace_with_openrouter_key
OPENROUTER_PREFLIGHT_MODEL=openai/gpt-5.4-nano
OPENROUTER_PARSER_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_REVIEW_MODEL=google/gemini-2.5-flash-lite
