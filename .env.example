PORT=8787
HOST=127.0.0.1
NODE_ENV=development
EDGELAB_DB_PATH=./data/edgelab.sqlite
EDGELAB_APP_URL=http://localhost:5173

# Stripe server credentials. Never expose these through VITE_ variables.
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRO_PRICE_ID=price_replace_me

# Legacy provider-neutral webhook retained for compatibility and isolated tests.
EDGELAB_BILLING_WEBHOOK_SECRET=replace-with-a-long-random-secret

# Local AI inference
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:12b
MARKET_DATA_CACHE_PATH=./data/market-cache


# Historical market data
DATABENTO_API_KEY=replace_with_databento_key

# Explicit one-time admin bootstrap; never infer among multiple accounts.
EDGELAB_ADMIN_EMAIL=owner@example.com

# Optional hosted AI fallback
OPENROUTER_API_KEY=replace_with_openrouter_key

